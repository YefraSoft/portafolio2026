        </div>
      </div>
    </header>

    <!-- Main Content Grid -->
    <div class="grid md:grid-cols-3 gap-12">
      <!-- Left Sidebar -->
      <aside class="space-y-12 md:col-span-1">
        <!-- Specialties -->
        <section data-animate>
