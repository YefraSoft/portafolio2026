              </h3>
              <p class="text-sm text-ink/60">{t("cv.exp2.company")}</p>
            </article>
          </div>
        </section>

        <!-- Education -->
        <section data-animate>
          <h2
            class="text-xs font-mono text-accent mb-6 uppercase tracking-widest flex items-center gap-2"
          >
            <span
              class="w-8 h-8 flex items-center justify-center rounded border border-accent/30 text-accent text-xs font-semibold"
