---
import { useTranslations } from "../../i18n/utils";
import type { Lang } from "../../i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<div id="cv" class="min-h-screen bg-surface-0 pt-32 pb-24 px-6">
  <div class="max-w-6xl mx-auto">
    <!-- Header Section -->
    <header class="mb-16 space-y-8">
      <div class="flex flex-col items-center md:flex-row md:items-start gap-6">
        <!-- Profile Image -->
        <div data-animate>
          <div
            class="w-auto h-62 rounded-xl overflow-hidden border border-subtle bg-surface-1 shrink-0"
          >
            <img
              src="https://res.cloudinary.com/yefrasoft/image/upload/v1743822052/profile_l5wsfc.webp"
              alt={t("cv.name")}
              class="w-full h-full object-cover"
            />
          </div>
        </div>

        <!-- Header Information -->
        <div class="space-y-4">
          <div data-animate>
            <h1
              class="font-display text-4xl md:text-5xl font-semibold text-ink mb-2"
            >
              {t("cv.name")}
            </h1>
            <p class="text-xl text-gradient-accent font-medium">
              {t("cv.role")}
            </p>
          </div>

          <!-- Contact Info -->
          <div
            class="grid md:grid-cols-2 gap-4 text-sm text-ink/60 pt-4"
            data-animate
          >
            <div class="flex items-center gap-2">
              <svg
                class="w-4 h-4 shrink-0"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
              >
                <path
                  d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
              <span>{t("cv.location")}</span>
            </div>
            <div class="flex items-center gap-2">
              <svg
                class="w-4 h-4 shrink-0"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
              >
                <path
                  d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
              <span>{t("cv.phone")}</span>
            </div>
            <div class="flex items-center gap-2">
              <svg
                class="w-4 h-4 shrink-0"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
              >
                <path
                  d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
                <path
                  d="m22 6-10 7L2 6"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
              <span>{t("cv.email")}</span>
            </div>
            <a
              href="https://github.com/YefraSoft"
              class="flex items-center gap-2 hover:text-accent transition-colors"
            >
              <svg
                class="w-4 h-4 shrink-0"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
              >
                <path
                  d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
