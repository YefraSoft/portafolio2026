---
interface Props {
  name: string;
  description: string;
  price: string;
  features: string[];
  link: string;
  highlight?: boolean;
}

const {
  name,
  description,
  price,
  features,
  link,
  highlight = false,
} = Astro.props as Props;
---

<div
  class={`group relative flex flex-col justify-between rounded-xl border p-6 
  bg-surface-1 transition-all duration-300 hover:border-accent/40 hover:-translate-y-1
  ${highlight ? "border-accent/40 bg-accent/5" : "border-subtle"}`} data-animate
>
  <!-- Badge -->
  {
    highlight && (
      <span class="absolute top-3 right-3 text-[10px] bg-accent text-white px-2 py-1 rounded">
        Popular
      </span>
    )
  }

  <!-- Header -->
  <div class="space-y-2">
    <h3 class="text-lg font-semibold text-ink">
      {name}
    </h3>
    <p class="text-sm text-ink/60">
      {description}
    </p>
  </div>

  <!-- Price -->
  <div class="mt-4">
    <p class="text-2xl font-semibold text-accent">
      {price}
    </p>
  </div>

  <!-- Features -->
  <ul class="mt-4 space-y-2 text-sm text-ink/60">
    {
      features.map((feature) => (
        <li class="flex items-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full bg-accent" />
          {feature}
        </li>
      ))
    }
  </ul>

  <!-- CTA -->
  <a
    href={link}
    class="mt-6 inline-flex items-center justify-center text-sm font-medium
    border border-subtle rounded-md py-2 hover:border-accent hover:bg-accent/5 transition"
  >
    Ver detalles →
  </a>
</div>
