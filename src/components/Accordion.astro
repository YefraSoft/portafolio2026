---
interface Props {
  title: string;
  subtitle?: string;
  defaultOpen?: boolean;
}

const { title, subtitle, defaultOpen = false } = Astro.props as Props;
---

<details
  class="group border border-subtle rounded-lg bg-surface-1
  open:border-accent/30 hover:border-accent/30
  transition-all duration-200" data-animate
  open={defaultOpen}
>
  <!-- Header -->
  <summary class="flex items-center justify-between cursor-pointer p-4">
    <div class="flex flex-col">
      <span class="font-medium text-ink/80 group-open:text-accent transition">
        {title}
      </span>

      {subtitle && <span class="text-xs text-ink/40">{subtitle}</span>}
    </div>

    <!-- Icon -->
    <span
      class="text-ink/40 transition-transform duration-200 group-open:rotate-180"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="w-4 h-4"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"
        ></path>
      </svg>
    </span>
  </summary>

  <!-- Content -->
  <div class="px-4 pb-4">
    <slot />
  </div>
</details>
