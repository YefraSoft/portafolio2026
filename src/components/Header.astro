---
import {
  getLangFromUrl,
  getLocalizedPath,
  getRouteWithoutLocale,
  useTranslations,
} from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const navLinks = [
  { key: "nav.cv" as const, href: getLocalizedPath("/cv", lang) },
  { key: "nav.portfolio" as const, href: getLocalizedPath("/portfolio", lang) },
  { key: "nav.services" as const, href: getLocalizedPath("/services", lang) },
  { key: "nav.blog" as const, href: getLocalizedPath("/blog", lang) },
  { key: "nav.contact" as const, href: getLocalizedPath("/contact", lang) },
];

const alternateLang = lang === "es" ? "en" : "es";
const currentRoute = getRouteWithoutLocale(Astro.url.pathname);
const alternatePath = getLocalizedPath(
  currentRoute ? `/${currentRoute}` : "/",
  alternateLang,
);
const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-50 bg-bg" id="site-header">
  <div
    class="absolute inset-0 bg-surface-0/80 backdrop-blur-md border-b border-subtle transition-opacity duration-300"
    id="header-bg"
  >
  </div>

  <div
    class="relative max-w-7xl mx-auto px-6 h-16 flex items-center justify-between"
  >
    <a
      href={getLocalizedPath("/", lang)}
      class="font-display text-lg font-semibold text-ink hover:text-accent transition-colors duration-200"
      aria-label="Home"
    >
      <span class="text-accent">Efrain Garcia/</span>YefraSoft
    </a>

    <nav class="hidden md:flex items-center gap-8" aria-label="Main navigation">
      {
        navLinks.map(({ key, href }) => (
          <a
            href={href}
            class:list={[
              "text-sm font-medium tracking-wide transition-colors duration-200 relative group",
              currentPath === href
                ? "text-accent"
                : "text-ink/60 hover:text-ink",
            ]}
          >
            {t(key)}
            <span
              class:list={[
                "absolute -bottom-0.5 left-0 h-px bg-accent transition-all duration-300",
                currentPath === href ? "w-full" : "w-0 group-hover:w-full",
              ]}
            />
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-4">
      <a
        href={alternatePath}
        class="text-xs font-mono font-medium text-ink/40 hover:text-accent transition-colors 
        duration-200 border border-subtle hover:border-accent/40 rounded px-2 py-1"
        aria-label={`Switch to ${alternateLang === "en" ? "English" : "Español"}`}
      >
        {alternateLang.toUpperCase()}
      </a>

      <button
        id="mobile-menu-toggle"
        class="md:hidden flex flex-col gap-1.5 p-1"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <span
          class="block w-5 h-px bg-ink transition-transform duration-300 origin-center"
          id="bar1"></span>
        <span
          class="block w-5 h-px bg-ink transition-opacity duration-300 origin-center"
          id="bar2"></span>
        <span
          class="block w-5 h-px bg-ink transition-transform duration-300 origin-center"
          id="bar3"></span>
      </button>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="md:hidden hidden absolute top-16 left-0 right-0 bg-surface-1 border-b border-subtle"
  >
    <nav class="flex flex-col px-6 py-4 gap-4">
      {
        navLinks.map(({ key, href }) => (
          <a
            href={href}
            class="text-sm font-medium text-ink/70 hover:text-accent transition-colors py-1"
          >
            {t(key)}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<div class="h-16"></div>

<script>
  const toggle = document.getElementById("mobile-menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const bar1 = document.getElementById("bar1");
  const bar2 = document.getElementById("bar2");
  const bar3 = document.getElementById("bar3");

  toggle?.addEventListener("click", () => {
    const isOpen = menu?.classList.toggle("hidden") === false;
    toggle.setAttribute("aria-expanded", String(isOpen));
    if (isOpen) {
      bar1?.classList.add("translate-y-2.5", "rotate-45");
      bar2?.classList.add("opacity-0");
      bar3?.classList.add("-translate-y-2.4", "-rotate-45");
    } else {
      bar1?.classList.remove("translate-y-2.5", "rotate-45");
      bar2?.classList.remove("opacity-0");
      bar3?.classList.remove("-translate-y-2.5", "-rotate-45");
    }
  });
</script>
