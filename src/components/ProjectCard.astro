---
interface Props {
  category: string;
  image: string;
  projects: Project[];
}

interface Project {
  name: string;
  description: string;
  link: string;
}

const { category, projects, image } = Astro.props;
---

<div
  class="group relative overflow-hidden rounded-xl border border-subtle bg-surface-1
  hover:border-accent/40 transition-all duration-300 animate-in fade-in slide-in-from-bottom-4" data-animate
>
  <!-- Imagen -->
  <div class="relative h-40 overflow-hidden">
    <img
      src={image}
      alt={category}
      class="w-full h-full object-cover opacity-70 group-hover:opacity-90 group-hover:scale-105 transition-all duration-500"
    />

    <!-- Overlay -->
    <div
      class="absolute inset-0 bg-linear-to-t from-black/40 via-black/10 to-transparent"
    >
    </div>

    <!-- Título -->
    <div class="absolute bottom-3 left-4">
      <p class="text-xs font-mono text-white/60 uppercase tracking-widest">
        Categoría
      </p>
      <h3 class="text-lg font-semibold text-white">
        {category}
      </h3>
    </div>
  </div>

  <!-- Contenido -->
  <div class="p-4 space-y-3">
    {
      projects.slice(0, 3).map((project) => (
        <a href={project.link} class="block group/item">
          <p class="text-sm font-medium text-ink group-hover/item:text-accent transition">
            {project.name}
          </p>
          <p class="text-xs text-ink/40">{project.description}</p>
        </a>
      ))
    }

    <!-- Ver más -->
    {
      projects.length > 3 && (
        <p class="text-xs text-accent mt-2">+{projects.length - 3} más...</p>
      )
    }
  </div>
</div>
