---
import { useTranslations } from "../i18n/utils";
import type { Lang } from "../i18n/utils";

interface Props {
  lang: Lang;
  phoneNumber?: string;
  email?: string;
}

const {
  lang,
  phoneNumber = "+523329611406",
  email = "yefrasoft@hotmail.com",
} = Astro.props;
const t = useTranslations(lang);

// Format phone number for WhatsApp (remove special characters)
const whatsappPhone = phoneNumber.replace(/\D/g, "");
const whatsappUrl = `https://wa.me/${whatsappPhone}`;
const telUrl = `tel:${phoneNumber}`;
const emailUrl = `mailto:${email}`;
---

<div class="space-y-8" data-animate>
  <!-- Header -->
  <div class="text-center">
    <p class="text-ink/60 text-sm">
      {t("contact.description")}
    </p>
  </div>

  <!-- Contact Buttons -->
  <div class="grid grid-cols-1 sm:grid-cols-3 sm:gap-4 gap-3">
    <!-- WhatsApp Button -->
    <a
      href={whatsappUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="flex flex-col items-center sm:gap-3 gap-2 sm:p-6 p-4 border border-subtle rounded-lg bg-surface-1 hover:bg-surface-2 hover:border-accent/40 transition-all duration-200 group"
    >
      <div
        class="sm:w-12 sm:h-12 w-10 h-10 flex items-center justify-center rounded-lg bg-accent/10 group-hover:bg-accent/20 transition-colors"
      >
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          class="text-accent"
        >
          <path
            d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
          ></path>
        </svg>
      </div>
      <div class="text-center">
        <p class="font-medium text-sm text-ink">
          {t("contact.whatsapp")}
        </p>
        <p class="text-xs text-ink/40 mt-1">
          {phoneNumber}
        </p>
      </div>
    </a>

    <!-- Email Button -->
    <a
      href={emailUrl}
      class="flex flex-col items-center sm:gap-3 gap-2 sm:p-6 p-4 border border-subtle rounded-lg bg-surface-1 hover:bg-surface-2 hover:border-accent/40 transition-all duration-200 group"
    >
      <div
        class="sm:w-12 sm:h-12 w-10 h-10 flex items-center justify-center rounded-lg bg-accent/10 group-hover:bg-accent/20 transition-colors"
      >
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          class="text-accent"
        >
          <rect x="2" y="4" width="20" height="16" rx="2"></rect>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
        </svg>
      </div>
      <div class="text-center">
        <p class="font-medium text-sm text-ink">
          {t("contact.email_button")}
        </p>
        <p class="text-xs text-ink/40 mt-1">
          {email}
        </p>
      </div>
    </a>

    <!-- Call Button -->
    <a
      href={telUrl}
      class="flex flex-col items-center sm:gap-3 gap-2 sm:p-6 p-4 border border-subtle rounded-lg bg-surface-1 hover:bg-surface-2 hover:border-accent/40 transition-all duration-200 group"
    >
      <div
        class="sm:w-12 sm:h-12 w-10 h-10 flex items-center justify-center rounded-lg bg-accent/10 group-hover:bg-accent/20 transition-colors"
      >
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          class="text-accent"
        >
          <path
            d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
          ></path>
        </svg>
      </div>
      <div class="text-center">
        <p class="font-medium text-sm text-ink">
          {t("contact.call")}
        </p>
        <p class="text-xs text-ink/40 mt-1">
          {phoneNumber}
        </p>
      </div>
    </a>
  </div>

  <!-- Divider -->
  <div class="flex items-center gap-4 pt-4">
    <div class="flex-1 h-px bg-subtle"></div>
    <span class="text-xs text-ink/40 font-mono">{t("contact.or")}</span>
    <div class="flex-1 h-px bg-subtle"></div>
  </div>

  <!-- Contact Form -->
  <div class="space-y-4 pt-4">
    <h4 class="font-display text-lg font-semibold">
      {t("contact.form.title")}
    </h4>

    <form class="space-y-4" method="POST" action="/api/contact">
      <!-- Service Type Select -->
      <div class="space-y-2">
        <label for="service-type" class="text-sm font-medium text-ink">
          {t("contact.form.subject")}
        </label>
        <select
          id="service-type"
          name="serviceType"
          required
          class="w-full px-4 py-2 bg-surface-1 border border-subtle rounded-lg text-ink font-mono text-sm focus:outline-none focus:border-accent transition-colors"
        >
          <option value="" disabled selected>
            {t("contact.form.select_placeholder")}
          </option>
          <option value="custom-software">
            {t("contact.form.custom_software")}
          </option>
          <option value="buy-license">
            {t("contact.form.buy_license")}
          </option>
          <option value="hire">
            {t("contact.form.hire")}
          </option>
        </select>
      </div>

     <!-- Name Input -->
<div class="space-y-2">
  <label for="name" class="text-sm font-medium text-ink">
    {t("contact.form.name")}
  </label>
  <input
    type="text"
    id="name"
    name="name"
    required
    class="w-full px-4 py-2 bg-surface-1 border border-subtle rounded-lg text-ink font-mono text-sm focus:outline-none focus:border-accent transition-colors"
    placeholder={t("contact.form.name.placeholder")}
  />
</div>

<!-- Email Input -->
<div class="space-y-2">
  <label for="email" class="text-sm font-medium text-ink">
    {t("contact.form.email")}
  </label>
  <input
    type="email"
    id="email"
    name="email"
    required
    class="w-full px-4 py-2 bg-surface-1 border border-subtle rounded-lg text-ink font-mono text-sm focus:outline-none focus:border-accent transition-colors"
    placeholder={t("contact.form.email.placeholder")}
  />
</div>

<!-- Message Textarea -->
<div class="space-y-2">
  <label for="message" class="text-sm font-medium text-ink">
    {t("contact.form.message")}
  </label>
  <textarea
    id="message"
    name="message"
    required
    rows="4"
    class="w-full px-4 py-2 bg-surface-1 border border-subtle rounded-lg text-ink font-mono text-sm focus:outline-none focus:border-accent transition-colors resize-none whitespace-pre-line"
    placeholder={t("contact.form.message.placeholder")}
  ></textarea>
</div>

      <!-- Submit Button -->
      <button
        type="submit"
        class="w-full px-6 py-3 bg-accent text-surface-0 text-sm font-medium rounded-lg hover:bg-accent/90 transition-all duration-200 hover:-translate-y-0.5"
      >
        {t("contact.form.submit")}
        <svg
          width="14"
          height="14"
          viewBox="0 0 14 14"
          fill="none"
          class="inline-flex ml-2"
        >
          <path
            d="M1 7h12M7 1l6 6-6 6"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </button>
    </form>
  </div>
</div>
